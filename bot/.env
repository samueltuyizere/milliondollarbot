# ─── Local PostgreSQL (same DB as dashboard) ─────────────────────────────────
DATABASE_URL="postgresql://postgres@localhost:5432/aitrader"

# ─── Dashboard URL (for heartbeats and trade reporting) ──────────────────────
DASHBOARD_URL="http://localhost:3000"

# ─── MT5 credentials (optional — MT5 must be open on Windows) ────────────────
# MT5 login is handled by the MetaTrader5 terminal directly
# These are only needed if you use mt5.login() explicitly
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=FundedNext-Server

# ─── Bot shared secret ────────────────────────────────────────────────────────
# Must match BOT_SECRET in dashboard/.env
BOT_SECRET=f1d04e9f4031b2f99f890bd56e61e2ccfb7234f8597ca03222243a5243c0ae82

# ─── Bot tuning ───────────────────────────────────────────────────────────────
POLL_SECONDS=15
HEARTBEAT_SECONDS=10
